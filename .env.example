# Copy to .env and replace every required value. Never commit .env.
# Bind to 0.0.0.0 for a new host unless you intentionally want a single LAN IP only.
APP_LISTEN_IP=0.0.0.0
APP_PORT=5059
APP_SECRET_KEY=replace-with-at-least-32-random-bytes
APP_ALLOWED_SUBNETS=192.168.1.0/24,127.0.0.1/32
APP_SESSION_SECURE=false
APP_DB_PATH=/data/caddy-admin.sqlite
APP_BACKUP_DIR=/data/backups
APP_WORKING_DIR=/data/working
APP_LOG_TAIL_DEFAULT=100
APP_ACCESS_LOG_RETENTION_DAYS=14
APP_ACCESS_LOG_INGEST_TAIL=5000

CADDY_HOST_DIR=/srv/caddy
CADDY_CONTAINER_NAME=caddy
CADDYFILE_APP_PATH=/managed-caddy/Caddyfile
CADDYFILE_CONTAINER_PATH=/etc/caddy/Caddyfile

# Run: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999
